@model TrendAi.ViewModels.InstagramTrendViewModel
@{
    ViewData["Title"] = "Instagram Trendleri";
}

<div class="row mb-4">
    <div class="col">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="display-6 fw-bold">
                    <i class="fab fa-instagram me-2" style="color:#E1306C;"></i>Instagram Trendleri
                </h1>
                <p class="text-muted">Instagram'da şu anda trend olan Reels ve postlar</p>
            </div>
            <form method="post" asp-action="Index" asp-controller="Instagram">
                <div class="input-group">
                    <select name="hashtag" class="form-select">
                        <option value="reels" selected="@(Model.Hashtag == "reels")">🎬 Reels</option>
                        <option value="kesfet" selected="@(Model.Hashtag == "kesfet")">🔍 Keşfet (TR)</option>
                        <option value="trending" selected="@(Model.Hashtag == "trending")">🔥 Trending</option>
                        <option value="viral" selected="@(Model.Hashtag == "viral")">💥 Viral</option>
                        <option value="foryou" selected="@(Model.Hashtag == "foryou")">✨ For You</option>
                        <option value="entertainment" selected="@(Model.Hashtag == "entertainment")">🎭 Eğlence</option>
                        <option value="fashion" selected="@(Model.Hashtag == "fashion")">👗 Moda</option>
                        <option value="food" selected="@(Model.Hashtag == "food")">🍕 Yemek</option>
                        <option value="travel" selected="@(Model.Hashtag == "travel")">✈️ Seyahat</option>
                        <option value="fitness" selected="@(Model.Hashtag == "fitness")">💪 Fitness</option>
                        <option value="technology" selected="@(Model.Hashtag == "technology")">💻 Teknoloji</option>
                        <option value="comedy" selected="@(Model.Hashtag == "comedy")">😂 Komedi</option>
                    </select>
                    <button type="submit" class="btn" style="background:#E1306C;color:white;">
                        <i class="fas fa-sync-alt me-1"></i>Trendleri Getir
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle me-2"></i>@Model.ErrorMessage
    </div>
}

@if (Model.Posts.Count > 0)
{
    <div class="alert alert-success mb-3">
        <i class="fab fa-instagram me-2"></i>
        <strong>@Model.Posts.Count</strong> trend Instagram postu bulundu.
        Hashtag: <strong>#@Model.Hashtag</strong>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var post in Model.Posts)
        {
            <div class="col">
                <div class="card h-100 shadow-sm video-card">
                    <div class="position-relative">
                        @if (!string.IsNullOrEmpty(post.ThumbnailUrl))
                        {
                            <img src="@post.ThumbnailUrl" class="card-img-top" alt="@post.Caption"
                                 style="height: 280px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="card-img-top d-flex align-items-center justify-content-center"
                                 style="height: 280px; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888);">
                                <i class="fab fa-instagram fa-3x text-white"></i>
                            </div>
                        }
                        <span class="badge position-absolute top-0 start-0 m-2" style="background:#E1306C;">
                            @post.PostType
                        </span>
                        @if (post.Duration > 0)
                        {
                            <span class="badge bg-dark position-absolute bottom-0 end-0 m-2">
                                <i class="fas fa-clock me-1"></i>@post.FormattedDuration
                            </span>
                        }
                    </div>
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-center mb-2">
                            @if (!string.IsNullOrEmpty(post.AuthorProfilePicUrl))
                            {
                                <img src="@post.AuthorProfilePicUrl" class="rounded-circle me-2"
                                     style="width:28px;height:28px;object-fit:cover;" />
                            }
                            <small class="fw-bold text-truncate">@@@post.AuthorUsername</small>
                        </div>

                        @if (!string.IsNullOrEmpty(post.Caption))
                        {
                            <p class="card-text small line-clamp-2 mb-2">@post.Caption</p>
                        }

                        @if (post.Hashtags.Count > 0)
                        {
                            <div class="mb-2">
                                @foreach (var tag in post.Hashtags.Take(3))
                                {
                                    <span class="badge me-1 mb-1" style="background:#E1306C;">#@tag</span>
                                }
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(post.MusicTitle))
                        {
                            <small class="text-muted"><i class="fas fa-music me-1"></i>@post.MusicTitle</small>
                        }

                        <div class="mt-auto">
                            <div class="d-flex justify-content-between text-muted small mt-2">
                                <span><i class="fas fa-play me-1"></i>@post.FormattedViews</span>
                                <span><i class="fas fa-heart me-1"></i>@post.FormattedLikes</span>
                                <span><i class="fas fa-comment me-1"></i>@post.CommentCount.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <div class="d-grid gap-2">
                            @if (!string.IsNullOrEmpty(post.InstagramUrl))
                            {
                                <a href="@post.InstagramUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                    <i class="fab fa-instagram me-1"></i>Instagram'da Gör
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model.IsLoaded)
{
    <div class="text-center py-5">
        <i class="fab fa-instagram fa-4x mb-3" style="color:#E1306C;"></i>
        <h4 class="text-muted">Henüz post yüklenmedi</h4>
        <p class="text-muted">Yukarıdan bir hashtag seçip "Trendleri Getir" butonuna tıklayın.</p>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fab fa-instagram fa-4x mb-3" style="color:#E1306C;"></i>
        <h4>Instagram Trend Analizine Hoş Geldiniz</h4>
        <p class="text-muted">Bir hashtag kategorisi seçip trend postları getirin.</p>
    </div>
}
