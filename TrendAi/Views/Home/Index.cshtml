@model TrendAi.ViewModels.TrendIndexViewModel
@{
    ViewData["Title"] = "Trend Videolar";
}

<div class="row mb-4">
    <div class="col">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="display-6 fw-bold">
                    <i class="fas fa-fire text-danger me-2"></i>Trend Videolar
                </h1>
                <p class="text-muted">YouTube'da şu anda en çok izlenen ve trend olan videolar</p>
            </div>
            <form method="post" asp-action="Index">
                <div class="input-group">
                    <select name="regionCode" class="form-select">
                        <option value="TR" selected="@(Model.RegionCode == "TR")">🇹🇷 Türkiye</option>
                        <option value="US" selected="@(Model.RegionCode == "US")">🇺🇸 ABD</option>
                        <option value="GB" selected="@(Model.RegionCode == "GB")">🇬🇧 İngiltere</option>
                        <option value="DE" selected="@(Model.RegionCode == "DE")">🇩🇪 Almanya</option>
                        <option value="FR" selected="@(Model.RegionCode == "FR")">🇫🇷 Fransa</option>
                        <option value="JP" selected="@(Model.RegionCode == "JP")">🇯🇵 Japonya</option>
                        <option value="KR" selected="@(Model.RegionCode == "KR")">🇰🇷 Güney Kore</option>
                        <option value="BR" selected="@(Model.RegionCode == "BR")">🇧🇷 Brezilya</option>
                        <option value="IN" selected="@(Model.RegionCode == "IN")">🇮🇳 Hindistan</option>
                    </select>
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-sync-alt me-1"></i>Trendleri Getir
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle me-2"></i>@Model.ErrorMessage
    </div>
}

@if (Model.Videos.Count > 0)
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 row-cols-xl-4 g-4">
        @foreach (var video in Model.Videos)
        {
            <div class="col">
                <div class="card h-100 shadow-sm video-card">
                    <div class="position-relative">
                        <img src="@video.ThumbnailUrl" class="card-img-top" alt="@video.Title"
                             style="height: 180px; object-fit: cover;" />
                        <span class="badge bg-dark position-absolute bottom-0 end-0 m-2">
                            <i class="fas fa-clock me-1"></i>@video.Duration
                        </span>
                        <span class="badge bg-danger position-absolute top-0 start-0 m-2">
                            @video.CategoryName
                        </span>
                    </div>
                    <div class="card-body d-flex flex-column">
                        <h6 class="card-title fw-bold line-clamp-2">@video.Title</h6>
                        <p class="card-text text-muted small mb-1">
                            <i class="fas fa-user me-1"></i>@video.ChannelTitle
                        </p>
                        <div class="mt-auto">
                            <div class="d-flex justify-content-between text-muted small mt-2">
                                <span><i class="fas fa-eye me-1"></i>@video.FormattedViews</span>
                                <span><i class="fas fa-thumbs-up me-1"></i>@video.LikeCount.ToString("N0")</span>
                                <span><i class="fas fa-comment me-1"></i>@video.CommentCount.ToString("N0")</span>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="@video.VideoUrl" target="_blank" class="btn btn-outline-danger btn-sm w-100">
                            <i class="fab fa-youtube me-1"></i>İzle
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model.IsLoaded)
{
    <div class="text-center py-5">
        <i class="fas fa-video-slash fa-3x text-muted mb-3"></i>
        <h4 class="text-muted">Trend video bulunamadı</h4>
        <p class="text-muted">Lütfen API anahtarınızı kontrol edin veya farklı bir bölge seçin.</p>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fas fa-hand-pointer fa-3x text-danger mb-3"></i>
        <h4 class="text-muted">Başlamak için "Trendleri Getir" butonuna tıklayın</h4>
        <p class="text-muted">YouTube'daki en güncel trend videoları analiz edeceğiz.</p>
    </div>
}
